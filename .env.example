# JobFox backend configuration.
# Copy to `.env.test` for local dev (run-dev.sh sources it automatically),
# or set these directly in Render → Environment for production.

# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/postgres
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
# Shared secret for POST /cron and /cron/replies (also signs session tokens
# and OAuth state — rotate with care).
PIPELINE_SECRET=change-me

# ── Recommended ─────────────────────────────────────────────────────────────
# Public origin of the deployed app (no trailing slash). Drives the Gmail
# OAuth redirect URI, Telegram button links, and ToS/Privacy links.
APP_URL=
# Telegram webhook hardening (set the same value via setWebhook secret_token).
TELEGRAM_WEBHOOK_SECRET=
# Encrypts Gmail refresh tokens at rest. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Gmail OAuth (per-user drafts + reply tracking) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Billing (Stripe) — all four required to enable ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_POWER=

# ── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Legacy SMTP fallback (optional; Gmail drafts are preferred) ─────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── Tunables ────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
WORLDWIDE_RATIO_DEFAULT=0.1
MIN_SCORE_NOTIFY_DEFAULT=6
MIN_SCORE_AUTO_APPLY_DEFAULT=8
